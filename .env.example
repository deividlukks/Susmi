# ===================================================================
# Susmi - Configurações Centralizadas (Exemplo)
# ===================================================================
# Copie este arquivo para .env e preencha com suas configurações

# -------------------------------------------------------------------
# DATABASE (PostgreSQL via Supabase)
# -------------------------------------------------------------------
# Para Supabase, use as seguintes URLs do seu projeto:
#
# DATABASE_URL: Connection Pooler (Transaction mode) - porta 6543
# Encontre em: Supabase Dashboard > Settings > Database > Connection string > URI
# Selecione "Transaction" no modo de pooling
#
# DIRECT_URL: Conexão direta - porta 5432
# Encontre em: Supabase Dashboard > Settings > Database > Connection string > URI
# Selecione "Session" no modo de pooling
#
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

DB_MAX_CONNECTIONS=10
DB_SSL=true

# -------------------------------------------------------------------
# REDIS (Cache e Filas)
# -------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# -------------------------------------------------------------------
# JWT (Autenticação)
# -------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -------------------------------------------------------------------
# API (Backend NestJS)
# -------------------------------------------------------------------
API_PORT=3001
API_HOST=localhost
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -------------------------------------------------------------------
# AI SERVICE (Python/FastAPI)
# -------------------------------------------------------------------
PYTHON_SERVICE_HOST=localhost
PYTHON_SERVICE_PORT=8000
PYTHON_SERVICE_TIMEOUT=30000
NESTJS_API_URL=http://localhost:3001/api
AI_API_DEBUG=true
AI_MODEL_PATH=./models
AI_ENABLE_FEATURES=true
AI_SECRET_KEY=your-super-secret-ai-key-change-me

# -------------------------------------------------------------------
# FRONTEND (Next.js)
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=Susmi
NEXT_PUBLIC_APP_VERSION=1.0.0

# -------------------------------------------------------------------
# EMAIL (Opcional)
# -------------------------------------------------------------------
EMAIL_ENABLED=false
EMAIL_FROM=noreply@smartplanner.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# -------------------------------------------------------------------
# PUSH NOTIFICATIONS (Opcional)
# -------------------------------------------------------------------
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -------------------------------------------------------------------
# DEVELOPMENT
# -------------------------------------------------------------------
NODE_ENV=development

# -------------------------------------------------------------------
# Telegram
# -------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=