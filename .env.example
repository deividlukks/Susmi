# ===================================================================
# Susmi - Configurações Centralizadas
# ===================================================================
# Copie este arquivo para .env e preencha com suas configurações
# IMPORTANTE: Este arquivo único é usado por todas as aplicações do monorepo

# -------------------------------------------------------------------
# DATABASE (PostgreSQL via Supabase)
# -------------------------------------------------------------------
# Para Supabase, use as seguintes URLs do seu projeto:
#
# DATABASE_URL: Connection Pooler (Transaction mode) - porta 6543
# Encontre em: Supabase Dashboard > Settings > Database > Connection string > URI
# Selecione "Transaction" no modo de pooling
#
# DIRECT_URL: Conexão direta - porta 5432
# Encontre em: Supabase Dashboard > Settings > Database > Connection string > URI
# Selecione "Session" no modo de pooling
#
# Formato: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres
DB_MAX_CONNECTIONS=10
DB_SSL=true

# -------------------------------------------------------------------
# REDIS (Cache e Filas)
# -------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# -------------------------------------------------------------------
# JWT (Autenticação)
# -------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -------------------------------------------------------------------
# API (Backend NestJS)
# -------------------------------------------------------------------
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# -------------------------------------------------------------------
# FRONTEND (Next.js)
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=Susmi
NEXT_PUBLIC_APP_VERSION=1.0.0

# -------------------------------------------------------------------
# SUPABASE (Autenticação e Storage)
# -------------------------------------------------------------------
# Encontre em: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -------------------------------------------------------------------
# AI SERVICE (Python/FastAPI)
# -------------------------------------------------------------------
PYTHON_SERVICE_HOST=localhost
PYTHON_SERVICE_PORT=8000
PYTHON_SERVICE_TIMEOUT=30000
NESTJS_API_URL=http://localhost:4000/api
AI_API_DEBUG=true
AI_MODEL_PATH=./models
AI_ENABLE_FEATURES=true
AI_SECRET_KEY=your-super-secret-ai-key-change-me

# -------------------------------------------------------------------
# LLM Configuration
# -------------------------------------------------------------------
LLM_PROVIDER=anthropic
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
ENABLE_LLM_FEATURES=false

# -------------------------------------------------------------------
# EMAIL (Opcional)
# -------------------------------------------------------------------
EMAIL_ENABLED=false
EMAIL_FROM=noreply@susmi.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# -------------------------------------------------------------------
# PUSH NOTIFICATIONS (Opcional)
# -------------------------------------------------------------------
PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -------------------------------------------------------------------
# TELEGRAM BOT (Opcional)
# -------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# -------------------------------------------------------------------
# DEVELOPMENT
# -------------------------------------------------------------------
NODE_ENV=development