{
  "name": "susmi",
  "version": "1.0.0",
  "private": true,
  "description": "S.U.S.M.I - Simplesmente Um Sistema Muito Inteligente",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "db:push": "pnpm --filter @susmi/database db:push",
    "db:migrate": "pnpm --filter @susmi/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @susmi/database db:migrate:deploy",
    "db:generate": "pnpm --filter @susmi/database db:generate",
    "db:studio": "pnpm --filter @susmi/database db:studio",
    "db:seed": "pnpm --filter @susmi/database db:seed",
    "test:connection": "node scripts/test-connection.js",
    "start:local": "pwsh scripts/start-local.ps1"
  },
  "devDependencies": {
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "glob": "^10.4.0",
      "rimraf": "^5.0.0",
      "inflight": "npm:@pnpm/noop@1.0.0"
    }
  }
}