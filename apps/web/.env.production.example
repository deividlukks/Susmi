# ===================================================================
# Susmi Web - Variáveis de Ambiente (Produção/Vercel)
# ===================================================================
# Configure estas variáveis no dashboard da Vercel:
# Project Settings > Environment Variables

# -------------------------------------------------------------------
# API Backend (OBRIGATÓRIO)
# -------------------------------------------------------------------
# URL da sua API NestJS em produção
# Exemplo: https://api.susmi.app/api ou https://susmi-api.railway.app/api
NEXT_PUBLIC_API_URL=https://sua-api-url.com/api

# URL do serviço Python de IA (opcional)
NEXT_PUBLIC_PYTHON_SERVICE_URL=https://sua-ai-service-url.com/api

# -------------------------------------------------------------------
# App Info
# -------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Susmi
NEXT_PUBLIC_APP_VERSION=1.0.0

# -------------------------------------------------------------------
# Ambiente
# -------------------------------------------------------------------
NODE_ENV=production
