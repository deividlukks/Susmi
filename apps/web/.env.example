# ===================================================================
# Susmi Web - Variáveis de Ambiente
# ===================================================================
# Copie este arquivo para .env.local para desenvolvimento local
# Para produção na Vercel, configure estas variáveis no dashboard

# -------------------------------------------------------------------
# API Backend (OBRIGATÓRIO)
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Serviço Python de IA (opcional)
NEXT_PUBLIC_PYTHON_SERVICE_URL=http://localhost:8000/api

# -------------------------------------------------------------------
# App Info
# -------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Susmi
NEXT_PUBLIC_APP_VERSION=1.0.0
